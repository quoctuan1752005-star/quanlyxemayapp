rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        getUserData().role == 'admin'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Rules for users
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && incoming().role == 'user';
      allow update: if isSignedIn() && (
        (isOwner(userId) && !incoming().diff(existing()).affectedKeys().hasAny(['role', 'uid', 'email'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Rules for vehicles
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn() && (isAdmin() || existing().assignedTo == request.auth.uid);
      allow write: if isAdmin();
    }

    // Rules for subcollections of vehicles
    match /vehicles/{vehicleId}/daily_logs/{logId} {
      function canAccessVehicle() {
        return isAdmin() || get(/databases/$(database)/documents/vehicles/$(vehicleId)).data.assignedTo == request.auth.uid;
      }
      allow read: if isSignedIn() && canAccessVehicle();
      allow create: if isSignedIn() && canAccessVehicle() && incoming().vehicleId == vehicleId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /vehicles/{vehicleId}/monthly_logs/{logId} {
      function canAccessVehicle() {
        return isAdmin() || get(/databases/$(database)/documents/vehicles/$(vehicleId)).data.assignedTo == request.auth.uid;
      }
      allow read: if isSignedIn() && canAccessVehicle();
      allow create: if isSignedIn() && canAccessVehicle() && incoming().vehicleId == vehicleId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /vehicles/{vehicleId}/maintenance_schedule/{scheduleId} {
      function canAccessVehicle() {
        return isAdmin() || get(/databases/$(database)/documents/vehicles/$(vehicleId)).data.assignedTo == request.auth.uid;
      }
      allow read: if isSignedIn() && canAccessVehicle();
      allow write: if isAdmin();
    }

    match /vehicles/{vehicleId}/maintenance_history/{historyId} {
      function canAccessVehicle() {
        return isAdmin() || get(/databases/$(database)/documents/vehicles/$(vehicleId)).data.assignedTo == request.auth.uid;
      }
      allow read: if isSignedIn() && canAccessVehicle();
      allow write: if isAdmin();
    }

    match /vehicles/{vehicleId}/part_replacement_history/{replacementId} {
      function canAccessVehicle() {
        return isAdmin() || get(/databases/$(database)/documents/vehicles/$(vehicleId)).data.assignedTo == request.auth.uid;
      }
      allow read: if isSignedIn() && canAccessVehicle();
      allow write: if isAdmin();
    }

    // Requests (e.g. log modifications)
    match /requests/{requestId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.requestedBy == request.auth.uid);
      allow create: if isSignedIn() && incoming().requestedBy == request.auth.uid && incoming().status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.targetUser == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || resource.data.targetUser == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Activity Logs
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}